---
import { Image } from "astro:assets";
import { projects } from "../data/projects";

const arrow = "M5 12h14M13 6l6 6-6 6";
---

<section id="work" class="scroll-mt-24 px-5 py-20 sm:px-8 sm:py-28">
  <div class="mx-auto max-w-5xl">
    <p
      class="text-sm font-medium uppercase tracking-[0.2em] text-accent-sky"
      data-reveal
    >
      Selected Work
    </p>
    <h2
      class="mt-6 max-w-2xl text-3xl font-semibold leading-[1.15] tracking-[-0.02em] sm:text-5xl"
      data-reveal
    >
      The building years — hands-on work, from hackathon MVPs to healthcare
      platforms.
    </h2>

    <div class="mt-20 space-y-24 sm:space-y-32">
      {
        projects.map((project, i) => (
          <article class="grid items-center gap-8 sm:gap-12 lg:grid-cols-2">
            {/* Image — 3D tilt */}
            <div
              class:list={[
                "tilt group relative overflow-hidden rounded-2xl glass p-2",
                i % 2 === 1 && "lg:order-2",
              ]}
              data-tilt
              data-reveal
            >
              <div class="tilt-inner overflow-hidden rounded-xl">
                <Image
                  src={project.image}
                  alt={project.imageAlt}
                  loading="lazy"
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 1024px) 512px, 100vw"
                  class="aspect-[16/10] w-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                />
              </div>
              <div
                class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                style="box-shadow: inset 0 0 60px -10px rgba(56,189,248,0.4);"
              />
            </div>

            {/* Copy */}
            <div class:list={[i % 2 === 1 && "lg:order-1"]} data-reveal>
              <div class="flex flex-wrap items-center gap-3">
                <span class="text-sm font-medium text-accent-sky">
                  {project.year}
                </span>
                <span class="h-px w-8 bg-hairline" />
                {
                  project.accolade && (
                    <span
                      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold text-white"
                      style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-indigo)); box-shadow: 0 0 18px -4px rgba(59,130,246,0.7);"
                    >
                      <svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-none stroke-current" stroke-width="2">
                        <path d="M8 21h8M12 17v4M7 4h10v4a5 5 0 0 1-10 0V4zM5 6H3v1a3 3 0 0 0 3 3M19 6h2v1a3 3 0 0 1-3 3" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      {project.accolade}
                    </span>
                  )
                }
              </div>

              <h3 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">
                {project.title}
              </h3>

              <p class="mt-4 text-[17px] leading-relaxed text-ink-soft">
                {project.blurb}
              </p>

              <ul class="mt-5 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <li class="rounded-full border border-hairline px-3 py-1 text-xs text-ink-soft">
                    {tag}
                  </li>
                ))}
              </ul>

              <div class="mt-6 flex flex-wrap items-center gap-5">
                {project.live && (
                  <a
                    href={project.live.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-magnetic
                    class="group/link inline-flex items-center gap-1.5 text-[15px] font-medium text-accent-sky transition-colors hover:text-ink"
                  >
                    {project.live.label}
                    <svg
                      viewBox="0 0 24 24"
                      class="h-4 w-4 fill-none stroke-current transition-transform group-hover/link:translate-x-0.5"
                      stroke-width="2"
                    >
                      <path d={arrow} stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </a>
                )}
                {project.repo && (
                  <a
                    href={project.repo.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-magnetic
                    class="group/link inline-flex items-center gap-1.5 text-[15px] font-medium text-ink transition-opacity hover:opacity-70"
                  >
                    {project.repo.label}
                    <svg
                      viewBox="0 0 24 24"
                      class="h-4 w-4 fill-none stroke-current transition-transform group-hover/link:translate-x-0.5"
                      stroke-width="2"
                    >
                      <path d={arrow} stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </a>
                )}
                {project.note && !project.live && !project.repo && (
                  <span class="text-[14px] italic text-ink-soft">
                    {project.note}
                  </span>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
