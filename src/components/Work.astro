---
import { projects } from "../data/projects";

const arrow =
  "M5 12h14M13 6l6 6-6 6"; // simple right-arrow path
---

<section
  id="work"
  class="scroll-mt-16 bg-[var(--color-canvas-alt)] px-5 py-28 sm:px-8 sm:py-40"
>
  <div class="mx-auto max-w-5xl">
    <p
      class="text-sm font-medium uppercase tracking-[0.2em] text-accent"
      data-reveal
    >
      Selected Work
    </p>
    <h2
      class="mt-6 max-w-2xl text-3xl font-semibold leading-[1.15] tracking-[-0.02em] sm:text-5xl"
      data-reveal
    >
      A decade of shipping — from hackathon MVPs to healthcare platforms.
    </h2>

    <div class="mt-20 space-y-24 sm:space-y-32">
      {
        projects.map((project, i) => (
          <article class="grid items-center gap-8 sm:gap-12 lg:grid-cols-2">
            {/* Image */}
            <div
              class:list={[
                "group relative overflow-hidden rounded-2xl border border-[var(--color-hairline)] bg-white shadow-[0_24px_70px_-30px_rgba(0,0,0,0.3)]",
                i % 2 === 1 && "lg:order-2",
              ]}
              data-reveal
            >
              <img
                src={project.image}
                alt={project.imageAlt}
                loading="lazy"
                class="aspect-[16/10] w-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              />
            </div>

            {/* Copy */}
            <div class:list={[i % 2 === 1 && "lg:order-1"]} data-reveal>
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium text-ink-soft">
                  {project.year}
                </span>
                <span class="h-px w-8 bg-[var(--color-hairline)]" />
              </div>

              <h3 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl">
                {project.title}
              </h3>

              <p class="mt-4 text-[17px] leading-relaxed text-ink-soft">
                {project.blurb}
              </p>

              <ul class="mt-5 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <li class="rounded-full border border-[var(--color-hairline)] px-3 py-1 text-xs text-ink-soft">
                    {tag}
                  </li>
                ))}
              </ul>

              <div class="mt-6 flex flex-wrap items-center gap-5">
                {project.live && (
                  <a
                    href={project.live.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex items-center gap-1.5 text-[15px] font-medium text-accent transition-colors hover:text-accent-hover"
                  >
                    {project.live.label}
                    <svg
                      viewBox="0 0 24 24"
                      class="h-4 w-4 fill-none stroke-current transition-transform group-hover:translate-x-0.5"
                      stroke-width="2"
                    >
                      <path
                        d={arrow}
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )}
                {project.repo && (
                  <a
                    href={project.repo.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex items-center gap-1.5 text-[15px] font-medium text-ink transition-opacity hover:opacity-60"
                  >
                    {project.repo.label}
                    <svg
                      viewBox="0 0 24 24"
                      class="h-4 w-4 fill-none stroke-current transition-transform group-hover:translate-x-0.5"
                      stroke-width="2"
                    >
                      <path
                        d={arrow}
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                )}
                {project.note && !project.live && !project.repo && (
                  <span class="text-[14px] italic text-ink-soft">
                    {project.note}
                  </span>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
