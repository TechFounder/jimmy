---
const links = [
  { label: "About", href: "#about" },
  { label: "Work", href: "#work" },
  { label: "Blog", href: "https://blog.jchen.me" },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
>
  <nav
    class="mx-auto mt-3 flex h-12 max-w-3xl items-center justify-between rounded-2xl px-4 transition-all duration-300 sm:px-5"
    data-nav-pill
  >
    <a
      href="#top"
      data-magnetic
      class="text-[15px] font-semibold tracking-tight text-ink transition-opacity hover:opacity-70"
    >
      Jimmy Chen
    </a>

    <ul class="flex items-center gap-5 sm:gap-7">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-[13px] text-ink-soft transition-colors hover:text-ink"
              {...link.href.startsWith("http")
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {}}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <button
          type="button"
          data-open-modal
          data-magnetic
          class="rounded-full bg-accent px-4 py-1.5 text-[13px] font-medium text-white transition-all hover:bg-accent-sky"
        >
          Contact
        </button>
      </li>
    </ul>
  </nav>
</header>

<script>
  // Frost the nav pill once the user scrolls past the hero fold.
  const pill = document.querySelector("[data-nav-pill]");
  if (pill) {
    const onScroll = () => {
      pill.classList.toggle("glass", window.scrollY > 40);
      pill.classList.toggle("shadow-[0_8px_30px_-12px_rgba(0,0,0,0.6)]", window.scrollY > 40);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
