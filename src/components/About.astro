---
// Modernized from the original site's bio + tech-stack list.
const stack = [
  { group: "Leadership", items: ["Team management", "Agile delivery", "Professional Scrum Master I"] },
  { group: "Quality & Testing", items: ["Test strategy", "Automation (Cypress, WebdriverIO)", "CI / CD"] },
  { group: "Languages", items: ["JavaScript / TypeScript", "Ruby"] },
  { group: "Frameworks", items: ["React", "Ruby on Rails", "Astro"] },
  { group: "Data", items: ["PostgreSQL", "MySQL"] },
  { group: "Cloud & Ops", items: ["AWS", "Cloudflare", "Git"] },
];
---

<section
  id="about"
  class="mx-auto max-w-5xl scroll-mt-24 px-5 py-28 sm:px-8 sm:py-40"
>
  <p
    class="text-sm font-medium uppercase tracking-[0.2em] text-accent-sky"
    data-reveal
  >
    About
  </p>

  <h2
    class="mt-6 max-w-3xl text-3xl font-semibold leading-[1.15] tracking-[-0.02em] sm:text-5xl"
    data-reveal
  >
    I lead engineering teams now — but I came up as a builder, and that
    still shapes how I work.
  </h2>

  <div class="mt-8 grid max-w-3xl gap-6 text-lg leading-relaxed text-ink-soft">
    <p data-reveal>
      I started out freelancing on frontends and shipping scrappy MVPs in
      hackathons, then went deep on full-stack work in healthcare tech. One of
      those early projects, RubiconMD, was acquired by Teladoc&nbsp;Health.
    </p>
    <p data-reveal>
      Today I'm an Engineering Manager for QA at Teladoc, leading the people,
      process, and tooling that keep software reliable at scale. Years close to
      the code are exactly what make me a better manager of it. I'm a certified
      Scrum Master and most energized where engineering meets product.
    </p>
  </div>

  <!-- Stack -->
  <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      stack.map((col, i) => (
        <div
          class="glass rounded-2xl p-6 transition-colors duration-300 hover:border-[rgba(56,189,248,0.4)]"
          data-reveal
          data-reveal-delay={(i % 3) + 1}
        >
          <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-accent-sky">
            {col.group}
          </h3>
          <ul class="mt-4 space-y-2">
            {col.items.map((item) => (
              <li class="text-[15px] text-ink">{item}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
