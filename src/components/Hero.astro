  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/jimmychen2/",
    path: "M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z",
  },
  {
    label: "GitHub",
    href: "https://github.com/TechFounder",
    path: "M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z",
  },
  {
    label: "X",
    href: "https://twitter.com/JimmyCsaid",
    path: "M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.46l8.6-9.83L0 1.15h7.6l5.24 6.93 6.06-6.93zm-1.29 19.5h2.04L6.48 3.24H4.29L17.61 20.65z",
  },
];
---

<section
  id="top"
  class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-5 text-center"
>
  <div data-hero-parallax class="flex flex-col items-center">
    <div
      class="mb-8 rounded-full p-[2px]"
      style="background: linear-gradient(135deg, var(--color-accent-sky), var(--color-accent-indigo));"
      data-hero-fade
      data-parallax-depth="0.4"
    >
      <img
        src="/images/headshot.png"
        alt="Jimmy Chen"
        width="112"
        height="112"
        class="h-28 w-28 rounded-full object-cover"
        style="box-shadow: 0 12px 50px -10px rgba(56,189,248,0.5);"
      />
    </div>

    <span
      class="mb-5 inline-flex items-center gap-2 rounded-full glass px-4 py-1.5 text-[13px] text-ink-soft"
      data-hero-fade
    >
      <span class="h-2 w-2 rounded-full bg-[#34d399] shadow-[0_0_10px_#34d399]"></span>
      Open to full-time, contract &amp; startup work
    </span>

    <h1
      class="max-w-3xl text-6xl font-bold leading-[1.0] tracking-[-0.04em] sm:text-8xl"
      data-hero-fade
    >
      <span class="gradient-text">Jimmy Chen</span>
    </h1>

    <p class="mt-6 max-w-xl text-xl text-ink-soft sm:text-2xl" data-hero-fade>
      Engineering Manager specializing in QA, most recently at
      Teladoc&nbsp;Health. Open to my next role — grounded in a decade of
      hands-on engineering.
    </p>

    <div class="mt-9 flex flex-col items-center gap-6" data-hero-fade>
      <button
        type="button"
        data-open-modal
        data-magnetic
        class="rounded-full px-8 py-3.5 text-[15px] font-medium text-white transition-all"
        style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-indigo)); box-shadow: 0 10px 40px -8px rgba(59,130,246,0.7);"
      >
        Get in touch
      </button>

      <div class="flex items-center gap-4">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              title={s.label}
              data-magnetic
              class="flex h-11 w-11 items-center justify-center rounded-full glass text-ink-soft transition-all duration-300 hover:text-ink"
            >
              <svg viewBox="0 0 24 24" class="h-[18px] w-[18px] fill-current">
                <path d={s.path} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="#about"
    aria-label="Scroll to content"
    class="absolute bottom-9 flex flex-col items-center gap-2 text-ink-soft transition-opacity hover:opacity-70"
    data-hero-fade
  >
    <span class="text-[11px] uppercase tracking-[0.2em]">Scroll</span>
    <svg
      viewBox="0 0 24 24"
      class="h-4 w-4 animate-bounce fill-none stroke-current"
      stroke-width="2"
    >
      <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>
