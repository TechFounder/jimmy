---
// Closing call-to-action. The form itself lives in the pop-out modal
// (ContactModal.astro); this band just invites a click.
---

<section id="contact" class="scroll-mt-24 px-5 py-28 sm:px-8 sm:py-40">
  <div
    class="glass relative mx-auto max-w-4xl overflow-hidden rounded-3xl px-8 py-16 text-center sm:py-24"
    data-reveal
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10"
      style="background: radial-gradient(60% 80% at 50% 0%, rgba(56,189,248,0.18), transparent 70%);"
    >
    </div>

    <h2
      class="mx-auto max-w-2xl text-4xl font-semibold leading-[1.1] tracking-[-0.02em] sm:text-6xl"
    >
      Let's build something <span class="gradient-text">together</span>.
    </h2>
    <p class="mx-auto mt-5 max-w-md text-lg text-ink-soft">
      Have a project, a question, or just want to say hello? Drop me a note —
      it lands straight in my inbox.
    </p>
    <button
      type="button"
      data-open-modal
      data-magnetic
      class="mt-9 rounded-full px-8 py-3.5 text-[15px] font-medium text-white transition-all"
      style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-indigo)); box-shadow: 0 10px 40px -8px rgba(59,130,246,0.7);"
    >
      Get in touch
    </button>
  </div>
</section>
